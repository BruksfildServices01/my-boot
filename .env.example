# Banco de dados Neon (PostgreSQL)
DATABASE_URL=postgres://usuario:senha@ep-xxx.sa-east-1.aws.neon.tech/neondb?sslmode=require

# Admin
ADMIN_USER=seu-usuario
ADMIN_PASSWORD=sua-senha-forte

# WhatsApp do vendedor (só números, com DDI: 5511999999999)
WHATSAPP_NUMBER=5511999999999

# URL pública do site (sem barra no final)
SITE_URL=https://seudominio.com.br

# Cloudflare R2
R2_ACCOUNT_ID=seu-account-id
R2_ACCESS_KEY_ID=sua-access-key
R2_SECRET_ACCESS_KEY=sua-secret-key
R2_BUCKET_NAME=nome-do-bucket
R2_PUBLIC_URL=https://pub-xxx.r2.dev

# Porta do servidor (padrão 8080)
PORT=8080
